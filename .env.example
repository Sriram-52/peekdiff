# peekdiff environment
#
# Public repos need NOTHING here — the /api/diff proxy works unauthenticated.
# These are only required to view PRIVATE repositories, which use a GitHub App.
# Copy to .env.local and fill in after registering the app (see README).

# GitHub App OAuth credentials (Settings -> Developer settings -> GitHub Apps).
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Optional: the app's URL slug, used to build an "install" link in the UI later.
# GITHUB_APP_SLUG=peekdiff
